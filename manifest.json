{
  "manifest_version": 3,
  "name": "HTTP Header Injector — Modify & Add Request Headers",
  "version": "1.0.2",
  "description": "Modify, add, and inject custom HTTP request headers on any page. Toggle each header on/off, scope by URL, and import/export.",
  "permissions": ["declarativeNetRequest", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon/icon16.png",
    "32": "icon/icon32.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Header Injector",
    "default_icon": {
      "16": "icon/icon16.png",
      "32": "icon/icon32.png",
      "48": "icon/icon48.png",
      "128": "icon/icon128.png"
    }
  }
}

{
  "manifest_version": 3,
  "name": "HTTP Header Injector — Modify Request & Response Headers",
  "version": "1.1.0",
  "description": "Add, modify & remove HTTP request and response headers on any site. Per-rule toggles, URL/method scoping, profiles, import/export.",
  "permissions": ["declarativeNetRequest", "declarativeNetRequestFeedback", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon/icon16.png",
    "32": "icon/icon32.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Header Injector",
    "default_icon": {
      "16": "icon/icon16.png",
      "32": "icon/icon32.png",
      "48": "icon/icon48.png",
      "128": "icon/icon128.png"
    }
  }
}
